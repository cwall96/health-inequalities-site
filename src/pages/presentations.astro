---
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../keystatic.config";
import Layout from "../layouts/Layout.astro";

const reader = createReader(process.cwd(), keystaticConfig);
const all = await reader.collections.presentations.all();

// Section order + labels (must match keystatic.config select values)
const sections = [
  { value: "inquiry", label: "National inquiries" },
  { value: "conference", label: "Conferences and seminars" },
  { value: "media", label: "Media coverage" },
];

const bySection = sections.map((s) => ({
  ...s,
  items: all
    .filter((p) => (p.entry.section ?? "conference") === s.value)
    .sort((a, b) => (b.entry.date ?? "").localeCompare(a.entry.date ?? "")),
}));

const fmt = (d: string | null) =>
  d
    ? new Date(d).toLocaleDateString("en-GB", { month: "long", year: "numeric" })
    : "";

export const prerender = true;
---

<Layout title="Presentations — Health Inequalities Team">
  <section class="section">
    <div class="container-page max-w-3xl">
      <p class="eyebrow">Dissemination</p>
      <h1 class="mt-3">Presentations</h1>

      {
        all.length === 0 ? (
          <p class="mt-10 text-muted">
            Nothing yet. Add presentations in the editor at <code>/keystatic</code>.
          </p>
        ) : (
          bySection
            .filter((s) => s.items.length > 0)
            .map((s) => (
              <div class="mt-12 first:mt-10">
                <h2 class="text-xl">{s.label}</h2>
                <ol class="mt-5 border-l-2 border-red-200 pl-6">
                  {s.items.map((p) => (
                    <li class="mb-6 last:mb-0">
                      <p class="text-sm text-red-600">{fmt(p.entry.date)}</p>
                      <p class="mt-1 leading-6 text-ink">
                        {p.entry.link ? <a href={p.entry.link}>{p.entry.title}</a> : p.entry.title}
                      </p>
                      {p.entry.venue && <p class="text-sm text-muted">{p.entry.venue}</p>}
                    </li>
                  ))}
                </ol>
              </div>
            ))
        )
      }
    </div>
  </section>
</Layout>