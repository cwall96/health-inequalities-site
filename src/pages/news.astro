---
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../keystatic.config";
import Layout from "../layouts/Layout.astro";

export const prerender = true;

const reader = createReader(process.cwd(), keystaticConfig);
const posts = (await reader.collections.news.all()).sort((a, b) =>
  (b.entry.publishedDate ?? "").localeCompare(a.entry.publishedDate ?? "")
);

const fmt = (d: string | null) =>
  d ? new Date(d).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" }) : "";
---

<Layout title="News — Health Inequalities Team">
  <section class="section">
    <div class="container-page max-w-3xl">
      <p class="eyebrow">Latest</p>
      <h1 class="mt-3">News</h1>

      {
        posts.length === 0 ? (
          <p class="mt-10 text-muted">
            Nothing yet. Write an item in the editor at <code>/keystatic</code>.
          </p>
        ) : (
          <div class="mt-10 space-y-8">
            {posts.map((p) => (
              <a href={`/news/${p.slug}`} class="block no-underline group">
                <article class="card transition-shadow group-hover:shadow-pop">
                  {p.entry.coverImage && (
                    <img
                      src={p.entry.coverImage}
                      alt={p.entry.title}
                      class="mb-4 h-48 w-full rounded-md object-cover"
                    />
                  )}
                  <p class="text-xs tracking-wide text-cloud-400">
                    {[fmt(p.entry.publishedDate), p.entry.author].filter(Boolean).join("  ·  ")}
                  </p>
                  <h2 class="mt-2 text-xl">{p.entry.title}</h2>
                  {p.entry.summary && <p class="mt-2 leading-7 text-muted">{p.entry.summary}</p>}
                  <span class="mt-3 inline-block text-sm text-red-600">Read more →</span>
                </article>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>
</Layout>