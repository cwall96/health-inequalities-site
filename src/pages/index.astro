---
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../keystatic.config";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";

const reader = createReader(process.cwd(), keystaticConfig);
const home = await reader.singletons.home.read();

const aboutHeading = home?.aboutHeading || "Understanding and reducing health inequalities";
const aboutBody =
  home?.aboutBody ||
  "The Health Inequalities Team is based in the Population Health Sciences Institute at Newcastle University.";

const paragraphs = aboutBody
  .split(/\n\s*\n/)
  .map((p) => p.trim())
  .filter(Boolean);

export const prerender = true;
---

<Layout>
  <Hero
    eyebrow={home?.eyebrow ?? "Population Health Sciences Institute, Newcastle University"}
    heading={home?.heading ?? "Health Inequalities Team"}
    intro={home?.intro ?? "We study how where you live shapes how long and how well you live, and what policy can do to close the gap."}
  />

  <section class="section">
    <div class="container-page max-w-3xl">
      <p class="eyebrow">About the team</p>
      <h2 class="mt-3">{aboutHeading}</h2>

      <div class="mt-6 space-y-4 leading-7 text-ink">
        {paragraphs.map((p) => <p>{p}</p>)}
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/people" class="btn-primary">Meet the team</a>
        <a href="/publications" class="btn-secondary">Read our research</a>
      </div>
    </div>
  </section>
</Layout>